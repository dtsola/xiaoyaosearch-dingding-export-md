{
  "manifest_version": 3,
  "name": "钉钉文档下载器",
  "version": "1.0.0",
  "description": "批量下载钉钉文档，支持导出为 docx、pdf、md、xlsx 等格式",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://alidocs.dingtalk.com/*",
    "https://docs.dingtalk.com/*"
  ],
  "action": {
    "default_title": "点击打开钉钉文档下载器"
  },
  "icons": {
    "128": "icons/icon.svg"
  }
}
