{
  "manifest_version": 3,
  "name": "小遥搜索 - 钉钉导出",
  "version": "1.0.0",
  "description": "批量导出钉钉文档，支持 docx、pdf、md、xlsx 等格式 | 小遥搜索生态工具",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://alidocs.dingtalk.com/*",
    "https://docs.dingtalk.com/*"
  ],
  "action": {
    "default_title": "点击打开小遥搜索 - 钉钉导出",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["images/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
