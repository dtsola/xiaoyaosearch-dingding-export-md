{
  "name": "xiaoyaosearch-dingding-export-md",
  "version": "1.0.0",
  "description": "小遥搜索钉钉导出工具 - 一键导出钉钉文档和知识库为Markdown格式",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write src/",
    "prepare": "husky install"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "pinia": "^2.2.8",
    "vue-router": "^4.5.0",
    "@vueuse/core": "^11.3.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^6.0.11",
    "typescript": "^5.7.2",
    "vue-tsc": "^2.2.0",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "@types/chrome": "^0.0.298"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "author": "dtsola",
  "license": "MIT",
  "keywords": [
    "dingtalk",
    "export",
    "markdown",
    "chrome-extension",
    "xiaoyaosearch"
  ]
}
