{
  "name": "xiaoyaosearch-dingding-export",
  "version": "1.0.0",
  "description": "将钉钉文档/知识库导出为 Markdown 格式的 CLI 工具",
  "main": "dist/index.js",
  "bin": {
    "dingding-export": "./bin/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "prepare": "husky install"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "dingding",
    "dingtalk",
    "markdown",
    "export",
    "cli",
    "xiaoyaosearch"
  ],
  "author": "dtsola",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dtsola/xiaoyaosearch-dingding-export-md"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "glob": "^13.0.6",
    "inquirer": "^13.4.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/cli-progress": "^3.11.6",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.5.2",
    "@types/tough-cookie": "^4.0.5",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.3"
  }
}
